{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["scripts/*.ts"],
  "project": ["src/**/*.ts", "setup/**/*.ts", "scripts/**/*.ts"],
  "ignoreDependencies": ["pino-pretty"],
  "ignoreExportsUsedInFile": false,
  "rules": {
    "files": "error",
    "exports": "error",
    "types": "error"
  }
}
