# NanoClaw — Non-secret configuration
# Copy to your deployment directory and customize.

# Agent container image (required)
CONTAINER_IMAGE=ghcr.io/your-username/nanoclaw-agent:latest

# Bot name (trigger pattern: @Andy)
ASSISTANT_NAME=Andy

# Container limits
# CONTAINER_TIMEOUT=1800000
# IDLE_TIMEOUT=1800000
# MAX_CONCURRENT_CONTAINERS=5
# CONTAINER_MAX_OUTPUT_SIZE=10485760

# Credential proxy port
# CREDENTIAL_PROXY_PORT=3001

# Logging
# LOG_LEVEL=info
